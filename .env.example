# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/poultry-farm

# ─── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens
JWT_SECRET=change_me_to_a_long_random_string

# ─── Supabase (optional – required for Supabase-based auth) ───────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── AI / Gemini (optional) ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── Frontend environment variables (prefix with VITE_) ──────────────────────
# Copy these into a frontend/.env or the root .env when running Vite
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
